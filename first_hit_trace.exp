#!/usr/bin/expect -f
set timeout 60
set password "B@nd73610421"
set user "root"
set host "168.231.118.173"

# Search for the very first request from this IP on the 21st
spawn ssh -o StrictHostKeyChecking=no $user@$host "grep '172.69.166.110' /var/log/nginx/access.log | head -n 20"
expect "password:"
send "$password\r"
expect eof
