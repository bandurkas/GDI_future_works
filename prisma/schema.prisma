// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

enum StudentStatus {
  LEAD
  ACTIVE
  COMPLETED
  DROPPED
}

enum TutorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProgramCategory {
  AI
  DATA
  CODING
  TEFL
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  BOOKED
  ATTENDED
  MISSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MIDTRANS
  STRIPE
}

enum PayoutStatus {
  PENDING
  PAID
}

enum LeadType {
  STUDENT
  TUTOR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
}

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
}

enum NotificationType {
  BOOKING
  PAYMENT
  REMINDER
}

// ------------------------------------------------------
// 1. USER SYSTEM
// ------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  name         String?
  email        String    @unique
  phone        String?
  passwordHash String?
  role         UserRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  student      Student?
  tutor        Tutor?
  notifications Notification[]

  @@index([email])
  @@index([role])
}

model Student {
  id        String        @id @default(uuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    StudentStatus @default(LEAD)
  country   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  bookings  Booking[]
  payments  Payment[]
  reviews   Review[]
}

model Tutor {
  id           String      @id @default(uuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?     @db.Text
  expertise    String[]
  ratingAvg    Float       @default(0)
  totalReviews Int         @default(0)
  isVerified   Boolean     @default(false)
  status       TutorStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  profile      TutorProfile?
  courses      Course[]
  availability TutorAvailability[]
  payouts      TutorPayout[]
  reviews      Review[]

  @@index([status])
}

model TutorProfile {
  id              String   @id @default(uuid())
  tutorId         String   @unique
  tutor           Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  headline        String?
  introVideoUrl   String?
  hourlyRate      Decimal? @db.Decimal(10, 2)
  languages       String[]
  experienceYears Int?
  portfolioUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ------------------------------------------------------
// 2. LEARNING STRUCTURE
// ------------------------------------------------------

model Program {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  description String?         @db.Text
  category    ProgramCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  courses     Course[]
}

model Course {
  id            String      @id @default(uuid())
  programId     String
  program       Program     @relation(fields: [programId], references: [id], onDelete: Restrict)
  tutorId       String
  tutor         Tutor       @relation(fields: [tutorId], references: [id], onDelete: Restrict)
  title         String
  description   String?     @db.Text
  price         Decimal     @db.Decimal(10, 2)
  durationWeeks Int
  level         CourseLevel
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  modules       CourseModule[]
  sessions      Session[]
  reviews       Review[]

  @@index([tutorId, isPublished])
}

model CourseModule {
  id         String   @id @default(uuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title      String
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lessons    Lesson[]

  @@unique([courseId, orderIndex])
}

model Lesson {
  id              String       @id @default(uuid())
  moduleId        String
  module          CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  description     String?      @db.Text
  durationMinutes Int
  orderIndex      Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([moduleId, orderIndex])
}

// ------------------------------------------------------
// 3. SCHEDULING & BOOKING
// ------------------------------------------------------

model TutorAvailability {
  id         String   @id @default(uuid())
  tutorId    String
  tutor      Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 0-6
  startTimeM Int // Minutes from midnight (0 - 1439)
  endTimeM   Int // Minutes from midnight (0 - 1439)
  timezone   String   @default("UTC")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tutorId, dayOfWeek])
}

model Session {
  id         String        @id @default(uuid())
  courseId   String
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  startTime  DateTime
  endTime    DateTime
  status     SessionStatus @default(SCHEDULED)
  meetingUrl String?
  capacity   Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  bookings   Booking[]

  @@index([courseId, startTime])
  @@index([status])
}

model Booking {
  id        String        @id @default(uuid())
  sessionId String
  session   Session       @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  status    BookingStatus @default(BOOKED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  payments  Payment[]

  @@unique([sessionId, studentId]) // Prevent duplicate bookings for same session
  @@index([studentId, status])
}

// ------------------------------------------------------
// 4. PAYMENTS
// ------------------------------------------------------

model Payment {
  id         String          @id @default(uuid())
  studentId  String
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  bookingId  String?
  booking    Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  amount     Decimal         @db.Decimal(10, 2)
  currency   String          @default("IDR")
  status     PaymentStatus   @default(PENDING)
  provider   PaymentProvider
  externalId String?         @unique
  metadata   Json? // For provider-specific response data
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([studentId, status])
  @@index([bookingId])
}

model TutorPayout {
  id          String       @id @default(uuid())
  tutorId     String
  tutor       Tutor        @relation(fields: [tutorId], references: [id], onDelete: Restrict)
  amount      Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tutorId, status])
}

// ------------------------------------------------------
// 5. REVIEWS
// ------------------------------------------------------

model Review {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutorId   String
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId]) // Prevent multiple reviews for same course
  @@index([tutorId, rating])
}

// ------------------------------------------------------
// 6. CRM (STRICTLY SEPARATE)
// ------------------------------------------------------

model Lead {
  id        String     @id @default(uuid())
  type      LeadType
  name      String
  email     String
  phone     String?
  source    String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  activities LeadActivity[]

  @@index([email, status])
}

model LeadActivity {
  id        String       @id @default(uuid())
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActivityType
  notes     String?      @db.Text
  createdAt DateTime     @default(now())
}

// ------------------------------------------------------
// 7. NOTIFICATIONS
// ------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model TutorApplication {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  name          String
  email         String   @unique
  linkedin      String?
  bio           String?
  expertise     String
  videoLink     String
  portfolioLink String?
  curriculum    String?
  lessonPlan    String?
  status        ApplicationStatus @default(PENDING)
}


