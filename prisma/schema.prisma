generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String?
  passwordHash  String?
  role          UserRole
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  name          String?
  avatarUrl     String?
  isActive      Boolean        @default(true)
  lastLogin     DateTime?
  permissions   Json?          @default("{}")
  notifications Notification[]
  student       Student?
  tutor         Tutor?
  auditLogs     AuditLog[]

  @@index([email])
  @@index([role])
}

model Student {
  id        String        @id @default(uuid())
  userId    String        @unique
  status    StudentStatus @default(LEAD)
  country   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  bookings  Booking[]
  payments  Payment[]
  reviews   Review[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Marketing Attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
}

model Tutor {
  id           String              @id @default(uuid())
  userId       String              @unique
  bio          String?
  expertise    String[]
  ratingAvg    Float               @default(0)
  totalReviews Int                 @default(0)
  isVerified   Boolean             @default(false)
  status       TutorStatus         @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  courses      Course[]
  reviews      Review[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability TutorAvailability[]
  payouts      TutorPayout[]
  profile      TutorProfile?

  @@index([status])
}

model TutorProfile {
  id              String   @id @default(uuid())
  tutorId         String   @unique
  headline        String?
  introVideoUrl   String?
  hourlyRate      Decimal? @db.Decimal(10, 2)
  languages       String[]
  experienceYears Int?
  portfolioUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tutor           Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Program {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  description String?
  category    ProgramCategory
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  courses     Course[]
}

model Course {
  id            String         @id @default(uuid())
  programId     String
  tutorId       String
  title         String
  description   String?
  durationWeeks Int
  level         CourseLevel
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  metadata      Json?          @default("{}")
  program       Program        @relation(fields: [programId], references: [id])
  tutor         Tutor          @relation(fields: [tutorId], references: [id])
  modules       CourseModule[]
  prices        CoursePrice[]
  reviews       Review[]
  sessions      Session[]

  @@index([tutorId, isPublished])
}

model CoursePrice {
  id        String   @id @default(uuid())
  courseId  String
  currency  String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, currency])
}

model CourseModule {
  id         String   @id @default(uuid())
  courseId   String
  title      String
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]

  @@unique([courseId, orderIndex])
}

model Lesson {
  id              String       @id @default(uuid())
  moduleId        String
  title           String
  description     String?
  durationMinutes Int
  orderIndex      Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  module          CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, orderIndex])
}

model TutorAvailability {
  id         String   @id @default(uuid())
  tutorId    String
  dayOfWeek  Int
  startTimeM Int
  endTimeM   Int
  timezone   String   @default("UTC")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tutor      Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId, dayOfWeek])
}

model Session {
  id         String        @id @default(uuid())
  courseId   String
  startTime  DateTime
  endTime    DateTime
  status     SessionStatus @default(SCHEDULED)
  meetingUrl String?
  capacity   Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?
  bookings   Booking[]
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, startTime])
  @@index([status])
}

model Booking {
  id        String        @id @default(uuid())
  sessionId String
  studentId String
  status    BookingStatus @default(BOOKED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  session   Session       @relation(fields: [sessionId], references: [id])
  student   Student       @relation(fields: [studentId], references: [id])
  payments  Payment[]

  @@unique([sessionId, studentId])
  @@index([studentId, status])
}

model Payment {
  id            String          @id @default(uuid())
  studentId     String
  bookingId     String?
  amount        Decimal         @db.Decimal(10, 2)
  currency      String          @default("IDR")
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider
  externalId    String?         @unique
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  transactionId String?         @unique
  booking       Booking?        @relation(fields: [bookingId], references: [id])
  student       Student         @relation(fields: [studentId], references: [id])

  @@index([studentId, status])
  @@index([bookingId])
}

model TutorPayout {
  id          String       @id @default(uuid())
  tutorId     String
  amount      Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tutor       Tutor        @relation(fields: [tutorId], references: [id])

  @@index([tutorId, status])
}

model Review {
  id        String   @id @default(uuid())
  studentId String
  tutorId   String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([tutorId, rating])
}

model Lead {
  id         String         @id @default(uuid())
  type       LeadType
  name       String
  email      String
  phone      String?
  source     String?
  status     LeadStatus     @default(NEW)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  activities LeadActivity[]

  // Marketing Attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  @@index([email, status])
}

model LeadActivity {
  id        String       @id @default(uuid())
  leadId    String
  type      ActivityType
  notes     String?
  createdAt DateTime     @default(now())
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorEmail String
  actorRole  String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model TutorApplication {
  id            String            @id @default(uuid())
  createdAt     DateTime          @default(now())
  name          String
  email         String            @unique
  linkedin      String?
  bio           String?
  expertise     String
  videoLink     String
  portfolioLink String?
  curriculum    String?
  lessonPlan    String?
  availability  String?
  timezone      String?
  status        ApplicationStatus @default(PENDING)
  phone         String?

  // Marketing Attribution
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
}

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
  OWNER
  SALES_MANAGER
  INSTRUCTOR
  SUPPORT
}

enum StudentStatus {
  LEAD
  ACTIVE
  COMPLETED
  DROPPED
  ARCHIVED
}

enum TutorStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ProgramCategory {
  AI
  DATA
  CODING
  TEFL
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  BOOKED
  ATTENDED
  MISSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PAYMENT_UPLOADED
  UNDER_REVIEW
}

enum PaymentProvider {
  MIDTRANS
  STRIPE
  QRIS
  PAYPAL
}

enum PayoutStatus {
  PENDING
  PAID
}

enum LeadType {
  STUDENT
  TUTOR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
}

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
}

enum NotificationType {
  BOOKING
  PAYMENT
  REMINDER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}
