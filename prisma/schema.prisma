// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// SYSTEM USERS (Super Admin, Account Manager, etc)
// ------------------------------------------------------
model AppUser {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String?  // Optional now because of Google Auth
  role          String   // 'super_admin', 'account_manager', 'video_manager', 'viewer'
  is_active     Boolean  @default(true)
  
  // Auth & Identity
  google_id     String?  @unique
  avatar_url    String?
  last_login    DateTime?

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  
  // Relations
  enrollments_created Enrollment[] @relation("EnrolledBy")
  payments_recorded   Payment[]    @relation("RecordedBy")
  notes_authored      Note[]       @relation("AuthoredBy")
  cohorts             CohortInstructor[]
  permissions         UserPermission[]
  managed_clients     Client[]     @relation("ManagedBy")
  leads_owned         Lead[]       @relation("LeadOwner")
  tasks_owned         Task[]       @relation("TaskOwner")
  activities          Activity[]   @relation("ActivityActor")
}

// ------------------------------------------------------
// USER PERMISSIONS (Granular Role Overrides)
// ------------------------------------------------------
model UserPermission {
  id             String   @id @default(cuid())
  user_id        String
  user           AppUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  permission_key String   // e.g. "view_all_enrollments"
  granted        Boolean  @default(true)
  created_at     DateTime @default(now())

  @@unique([user_id, permission_key])
}

// ------------------------------------------------------
// CLIENT DIRECTORY
// ------------------------------------------------------
model Client {
  id             String    @id @default(cuid())
  full_name      String
  email          String    @unique
  phone_whatsapp String
  city           String?
  country        String?
  source         String?   // 'instagram', 'whatsapp', 'website', 'referral', 'other'
  status         String    @default("active") // 'active', 'completed', 'dropped', 'refunded'
  tags           String?   // JSON string of arrays
  follow_up_date DateTime?
  
  // Auth & Identity
  google_id      String?   @unique
  avatar_url     String?
  last_login     DateTime?
  
  // RBAC Assignment
  account_manager_id String?
  account_manager    AppUser?  @relation("ManagedBy", fields: [account_manager_id], references: [id], onDelete: SetNull)
  
  // Timestamps (UTC in DB, mapped to WIB locally)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime? // Soft deletes for financial integrity

  // Relations
  enrollments    Enrollment[]
  notes          Note[]
  waitlists      Waitlist[]
}

// ------------------------------------------------------
// COURSES & COHORTS
// ------------------------------------------------------
model Course {
  id            String   @id @default(cuid())
  name          String
  description   String?
  default_price Float
  currency      String   @default("IDR") // 'IDR', 'MYR'
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  cohorts       Cohort[]
  leads         Lead[]
}

model Cohort {
  id             String   @id @default(cuid())
  course_id      String
  course         Course   @relation(fields: [course_id], references: [id], onDelete: Restrict)
  
  name           String   // e.g. "Apr 12–13"
  start_date     DateTime
  end_date       DateTime
  max_seats      Int      @default(12)
  price_override Float?
  
  meeting_url    String?  // Zoom
  resources_url  String?  // Drive
  status         String   @default("upcoming") // 'upcoming', 'active', 'completed', 'cancelled'
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  enrollments    Enrollment[]
  instructors    CohortInstructor[]
  waitlists      Waitlist[]
}

// Pivot Table for Many-to-Many
model CohortInstructor {
  id        String  @id @default(cuid())
  cohort_id String
  user_id   String
  
  cohort    Cohort   @relation(fields: [cohort_id], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([cohort_id, user_id])
}

// ------------------------------------------------------
// ENROLLMENTS & WAITLISTS
// ------------------------------------------------------
model Enrollment {
  id             String   @id @default(cuid())
  client_id      String
  cohort_id      String
  enrolled_by_id String?
  
  client         Client   @relation(fields: [client_id], references: [id], onDelete: Restrict)
  cohort         Cohort   @relation(fields: [cohort_id], references: [id], onDelete: Restrict)
  enrolled_by    AppUser? @relation("EnrolledBy", fields: [enrolled_by_id], references: [id], onDelete: SetNull)

  price_agreed   Float
  payment_status String   @default("unpaid") // 'unpaid', 'partial', 'paid', 'refunded'
  total_paid     Float    @default(0)
  status         String   @default("active") // 'active', 'completed', 'dropped'
  
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  payments       Payment[]
  attendance     Attendance[]
}

model Waitlist {
  id         String   @id @default(cuid())
  client_id  String
  cohort_id  String
  
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  cohort     Cohort   @relation(fields: [cohort_id], references: [id], onDelete: Cascade)
  
  joined_at  DateTime @default(now())

  @@unique([client_id, cohort_id])
}

// ------------------------------------------------------
// FINANCE & TRACKING
// ------------------------------------------------------
model Payment {
  id               String   @id @default(cuid())
  enrollment_id    String
  enrollment       Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Restrict)
  transaction_id   String?    @unique
  
  transaction_type String   @default("payment") // 'payment', 'refund'
  amount           Float
  currency         String   @default("IDR")
  method           String   // 'transfer', 'cash', 'installment', 'midtrans'
  proof_url        String?
  notes            String?
  
  paid_at          DateTime
  recorded_by_id   String?
  recorded_by      AppUser?  @relation("RecordedBy", fields: [recorded_by_id], references: [id], onDelete: SetNull)
  
  created_at       DateTime @default(now())
}

model Attendance {
  id            String   @id @default(cuid())
  enrollment_id String
  enrollment    Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  
  session_date  DateTime
  status        String   // 'present', 'absent', 'late'
  created_at    DateTime @default(now())

  @@unique([enrollment_id, session_date])
}

model Note {
  id         String   @id @default(cuid())
  client_id  String
  author_id  String?
  
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  author     AppUser? @relation("AuthoredBy", fields: [author_id], references: [id], onDelete: SetNull)
  
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model PasswordReset {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  created_at DateTime @default(now())
  
  @@index([email])
}

// ------------------------------------------------------
// CRM V2 PHASE 1: LEADS & PIPELINE
// ------------------------------------------------------

model PipelineStage {
  id          String   @id @default(cuid())
  name        String   // "New Lead", "Contacted", "Consultation", "Application"
  order       Int
  color       String?  // for UI pill
  leads       Lead[]
}

model Lead {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @unique
  phone          String
  country        String?
  age            Int?
  englishLevel   String?
  education      String?
  careerGoal     String?
  source         String?
  campaign       String?
  leadScore      Float    @default(0)
  status         String   @default("active") // active, won, lost

  interestedCourseId String?
  interestedCourse   Course? @relation(fields: [interestedCourseId], references: [id])

  ownerId        String?
  owner          AppUser? @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  stageId        String
  stage          PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activities     Activity[]
  tasks          Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("medium") // low, medium, high
  dueDate     DateTime?
  status      String   @default("pending") // pending, completed
  
  ownerId     String
  owner       AppUser  @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // "STATUS_CHANGE", "NOTE_ADDED", "TASK_COMPLETED", "MANUAL_LOG"
  content     String
  metadata    String?  // JSON string for specific event data
  
  actorId     String
  actor       AppUser  @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

