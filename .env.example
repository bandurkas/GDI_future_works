# ─── GDI FutureWorks — Required Environment Variables ───
# Copy to .env and fill in values. DO NOT commit .env!

# ── Database ──
DATABASE_URL="postgresql://user:pass@localhost:5432/gdi_future_works?schema=public"

# ── Auth (NextAuth v5) ──
AUTH_URL="https://gdifuture.works"
NEXTAUTH_URL="https://gdifuture.works"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="same-as-AUTH_SECRET"
JWT_SECRET="your-jwt-secret"

# ── Google OAuth (REQUIRED for Google login) ──
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="same-as-GOOGLE_CLIENT_ID"

# ── Google Sheets (CRM sync) ──
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-sa@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_SHEET_ID="your-sheet-id"

# ── Payments (Midtrans) ──
MIDTRANS_SERVER_KEY="your-server-key"
MIDTRANS_CLIENT_KEY="your-client-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="same-as-MIDTRANS_CLIENT_KEY"

# ── Email (Resend) ──
RESEND_API_KEY="re_your-key"
RESEND_FROM_EMAIL="GDI FutureWorks <leads@gdifuture.works>"
SALES_NOTIFY_EMAIL="sales@example.com"

# ── WhatsApp (Whapi) ──
WHAPI_API_URL="https://gate.whapi.cloud"
WHAPI_TOKEN="your-whapi-token"

# ── ManyChat ──
MANYCHAT_API_KEY="your-key"
MANYCHAT_PAGE_ID="your-page-id"
MANYCHAT_WEBHOOK_KEY="your-webhook-key"

# ── AI ──
ANTHROPIC_API_KEY="sk-ant-your-key"
